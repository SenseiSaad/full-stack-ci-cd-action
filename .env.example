# Local development defaults.
SECRET_KEY=replace-with-a-long-random-django-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend

DB_NAME=portfolio
DB_USER=portfolio
DB_PASSWORD=portfolio
DB_HOST=db
DB_PORT=5432

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
CORS_ALLOWED_ORIGINS=http://localhost:3000
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_EMAIL=admin@example.local
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Updated EC2/RDS production env.
# Copy this section to /home/ubuntu/app/.env on the EC2 server and replace
# placeholders with terraform output values and your real secrets.
# SECRET_KEY=replace-with-a-new-long-random-production-secret
# DEBUG=False
# ALLOWED_HOSTS=YOUR_EC2_PUBLIC_IP,slancer.site,www.slancer.site,api.slancer.site,localhost,127.0.0.1,backend
# DATABASE_ENGINE=django.db.backends.postgresql
# DB_NAME=portfolio
# DB_USER=postgres
# DB_PASSWORD=replace-with-rds-password
# DB_HOST=replace-with-rds-endpoint-without-port
# DB_PORT=5432
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
# CORS_ALLOWED_ORIGINS=http://YOUR_EC2_PUBLIC_IP,http://slancer.site,http://www.slancer.site,https://slancer.site,https://www.slancer.site

# EC2 + Nginx production example.
# Use terraform output rds_host for DB_HOST, not rds_endpoint with :5432.
# SECRET_KEY=replace-with-a-new-long-random-production-secret
# DEBUG=False
# ALLOWED_HOSTS=YOUR_EC2_PUBLIC_IP,slancer.site,www.slancer.site,api.slancer.site,localhost,127.0.0.1,backend
# DATABASE_ENGINE=django.db.backends.postgresql
# DB_NAME=portfolio
# DB_USER=postgres
# DB_PASSWORD=replace-with-rds-password
# DB_HOST=replace-with-rds-host-without-port
# DB_PORT=5432
# AWS_STORAGE_BUCKET_NAME=replace-with-terraform-output-s3_bucket_name
# AWS_S3_REGION_NAME=us-east-1
# CORS_ALLOWED_ORIGINS=http://YOUR_EC2_PUBLIC_IP,http://slancer.site,http://www.slancer.site,https://slancer.site,https://www.slancer.site
